# Core API settings
SENJI_TOKEN=dev-token
READABILITY_URL=http://readability:3000
LOG_LEVEL=INFO

# Database
SQLITE_DB_PATH=/opt/vault/jobs.db

# OLLAMA LLM Configuration (required for wiki + vision features)
OLLAMA_BASE_URL=http://localhost:11434

# Vault path for storing clipped articles
VAULT_PATH=/opt/vault

# Model names for different tasks
OLLAMA_MODEL=qwen3:8b
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_EMBED_MODEL=bge-m3
