# Bearer token for API authentication.
# Generated by you; used in Authorization header: "Bearer <SENJI_TOKEN>"
# Example: openssl rand -hex 32
SENJI_TOKEN=your-bearer-token-here

# URL for Readability service (HTML/web page extraction and conversion)
# In Docker Compose, this resolves to the readability service container
READABILITY_URL=http://readability:3000

# Ollama LAN endpoint (required for wiki + vision features)
OLLAMA_BASE_URL=http://10.1.1.222:11434

# Vault path for storing raw/ + wiki/ directories (default: /opt/vault)
VAULT_PATH=/opt/vault

# Ollama model for text embedding and general tasks
OLLAMA_MODEL=qwen3:8b

# Ollama model for vision tasks (image analysis)
OLLAMA_VISION_MODEL=qwen2.5vl:7b

# Ollama model for semantic embeddings
OLLAMA_EMBED_MODEL=bge-m3
