# Bearer token for API authentication.
# Generated by you; used in Authorization header: "Bearer <SENJI_TOKEN>"
# Example: openssl rand -hex 32
SENJI_TOKEN=your-bearer-token-here

# URL for Readability service (HTML/web page extraction and conversion)
# In Docker Compose, this resolves to the readability service container
READABILITY_URL=http://readability:3000
