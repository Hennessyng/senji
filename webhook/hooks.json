[
  {
    "id": "deploy-senji",
    "execute-command": "/opt/stacks/homelab/scripts/deploy.sh",
    "command-working-directory": "/opt/stacks/homelab",
    "response-message": "Deploy triggered",
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "REPLACE_WITH_YOUR_WEBHOOK_SECRET",
        "parameter": {
          "source": "header",
          "name": "X-Webhook-Secret"
        }
      }
    }
  }
]
