[
  {
    "id": "deploy-senji",
    "execute-command": "/bin/bash",
    "pass-arguments-to-command": [
      { "source": "string", "name": "/opt/stacks/homelab/senji/scripts/deploy.sh" }
    ],
    "command-working-directory": "/opt/stacks/homelab/senji",
    "response-message": "Deploy triggered",
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "REPLACE_WITH_YOUR_WEBHOOK_SECRET",
        "parameter": {
          "source": "header",
          "name": "X-Webhook-Secret"
        }
      }
    }
  }
]
